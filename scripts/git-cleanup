#!/usr/bin/env bash
# git-cleanup — delete local branches that have been merged into the default branch.
set -euo pipefail

default="$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's@^origin/@@')"
default="${default:-main}"

git fetch --all --prune

merged=$(git branch --merged "$default" | grep -vE "^\*|\s*${default}\s*$|\s*master\s*$|\s*develop\s*$" || true)

if [ -z "$merged" ]; then
    echo "nothing to clean up."
    exit 0
fi

echo "the following merged branches will be deleted:"
echo "$merged"
read -r -p "proceed? [y/N] " answer
case "$answer" in
    y|Y) echo "$merged" | xargs -n1 git branch -d ;;
    *)   echo "aborted." ;;
esac
